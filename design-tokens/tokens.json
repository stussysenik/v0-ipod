{
	"$schema": "https://raw.githubusercontent.com/design-tokens/community-group/main/packages/format/schemas/tokens.schema.json",
	"$description": "iPod design tokens extracted from tailwind.config.ts and app/globals.css. Source of truth is code — this file is regenerated by `bun run tokens:extract`. Do not hand-edit.",
	"Primitives": {
		"color": {
			"white": {
				"$type": "color",
				"$value": "#FFFFFF"
			},
			"black": {
				"$type": "color",
				"$value": "#000000"
			}
		},
		"radius": {
			"base": {
				"$type": "dimension",
				"$value": "0.5rem"
			}
		}
	},
	"Semantic": {
		"color": {
			"background": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 100%)",
					"dark": "hsl(0 0% 3.9%)"
				}
			},
			"foreground": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 3.9%)",
					"dark": "hsl(0 0% 98%)"
				}
			},
			"card": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 100%)",
					"dark": "hsl(0 0% 3.9%)"
				}
			},
			"card-foreground": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 3.9%)",
					"dark": "hsl(0 0% 98%)"
				}
			},
			"popover": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 100%)",
					"dark": "hsl(0 0% 3.9%)"
				}
			},
			"popover-foreground": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 3.9%)",
					"dark": "hsl(0 0% 98%)"
				}
			},
			"primary": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 9%)",
					"dark": "hsl(0 0% 98%)"
				}
			},
			"primary-foreground": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 98%)",
					"dark": "hsl(0 0% 9%)"
				}
			},
			"secondary": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 96.1%)",
					"dark": "hsl(0 0% 14.9%)"
				}
			},
			"secondary-foreground": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 9%)",
					"dark": "hsl(0 0% 98%)"
				}
			},
			"muted": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 96.1%)",
					"dark": "hsl(0 0% 14.9%)"
				}
			},
			"muted-foreground": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 45.1%)",
					"dark": "hsl(0 0% 63.9%)"
				}
			},
			"accent": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 96.1%)",
					"dark": "hsl(0 0% 14.9%)"
				}
			},
			"accent-foreground": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 9%)",
					"dark": "hsl(0 0% 98%)"
				}
			},
			"destructive": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 84.2% 60.2%)",
					"dark": "hsl(0 62.8% 30.6%)"
				}
			},
			"destructive-foreground": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 98%)",
					"dark": "hsl(0 0% 98%)"
				}
			},
			"border": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 89.8%)",
					"dark": "hsl(0 0% 14.9%)"
				}
			},
			"input": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 89.8%)",
					"dark": "hsl(0 0% 14.9%)"
				}
			},
			"ring": {
				"$type": "color",
				"$value": {
					"light": "hsl(0 0% 3.9%)",
					"dark": "hsl(0 0% 83.1%)"
				}
			}
		},
		"radius": {
			"lg": {
				"$type": "dimension",
				"$value": "0.5rem"
			},
			"md": {
				"$type": "dimension",
				"$value": "calc(0.5rem - 2px)"
			},
			"sm": {
				"$type": "dimension",
				"$value": "calc(0.5rem - 4px)"
			}
		}
	},
	"Component": {
		"ipod": {
			"shell": {
				"default-black": {
					"$type": "color",
					"$value": "#1A1A1A",
					"$description": "Default shell color for the 2008 Black preset"
				},
				"default-silver": {
					"$type": "color",
					"$value": "#C8C9CB",
					"$description": "Default shell color for the 2008 Silver preset"
				}
			},
			"backdrop": {
				"default": {
					"$type": "color",
					"$value": "#FFFFFF",
					"$description": "Default backdrop color for the staging frame"
				}
			}
		}
	}
}
