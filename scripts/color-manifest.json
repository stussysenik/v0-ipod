{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "description": "Canonical color token manifest for iPod Classic anniversary tribute. All color decisions must be auditable through dcal.",

  "authenticCaseColors": [
    {
      "label": "White (1st-3rd Gen)",
      "hex": "#FFFFFF",
      "family": "white",
      "generation": "1-3"
    },
    {
      "label": "White (4th Gen)",
      "hex": "#F7F7F7",
      "family": "white",
      "generation": "4"
    },
    {
      "label": "White (5th Gen)",
      "hex": "#F5F5F5",
      "family": "white",
      "generation": "5"
    },
    {
      "label": "Black (5th Gen)",
      "hex": "#1A1A1A",
      "family": "black",
      "generation": "5"
    },
    {
      "label": "Silver (Classic 6th)",
      "hex": "#D9D9D9",
      "family": "silver",
      "generation": "6"
    },
    {
      "label": "Black (Classic 6th)",
      "hex": "#1C1C1E",
      "family": "black",
      "generation": "6"
    },
    {
      "label": "Classic Black 2008",
      "hex": "#2D2F34",
      "family": "black",
      "generation": "6-late"
    },
    { "label": "U2 Black Front", "hex": "#111111", "family": "u2", "generation": "u2" },
    { "label": "U2 Red Wheel", "hex": "#B00020", "family": "u2", "generation": "u2" }
  ],

  "surfaceTokens": {
    "shell.default": { "hex": "#FBFBF8", "role": "shell", "family": "neutral" },
    "backdrop.default": { "hex": "#F3F3EE", "role": "backdrop", "family": "neutral" },

    "wheel.border": { "hex": "#DADCDD", "role": "wheel", "family": "neutral" },
    "wheel.gradient.from": { "hex": "#FAFAF8", "role": "wheel", "family": "neutral" },
    "wheel.gradient.via": { "hex": "#F3F3F0", "role": "wheel", "family": "neutral" },
    "wheel.gradient.to": { "hex": "#EAEAE6", "role": "wheel", "family": "neutral" },

    "wheel.center.border": {
      "hex": "#E3E5E6",
      "role": "wheel-center",
      "family": "neutral"
    },
    "wheel.center.from": {
      "hex": "#FBFBFA",
      "role": "wheel-center",
      "family": "neutral"
    },
    "wheel.center.via": { "hex": "#F4F4F2", "role": "wheel-center", "family": "neutral" },
    "wheel.center.to": { "hex": "#E8E8E4", "role": "wheel-center", "family": "neutral" },

    "wheel.label": { "hex": "#808791", "role": "text", "family": "cool" },

    "screen.surround.top": {
      "hex": "#0D0D0D",
      "role": "screen-surround",
      "family": "neutral"
    },
    "screen.surround.mid": {
      "hex": "#181818",
      "role": "screen-surround",
      "family": "neutral"
    },
    "screen.surround.bottom": {
      "hex": "#060606",
      "role": "screen-surround",
      "family": "neutral"
    },
    "screen.border": { "hex": "#525252", "role": "border", "family": "neutral" },

    "screen.statusbar.bg.from": {
      "hex": "#F1F1F1",
      "role": "screen-content",
      "family": "neutral"
    },
    "screen.statusbar.bg.to": {
      "hex": "#CDCDCD",
      "role": "screen-content",
      "family": "neutral"
    },
    "screen.content.bg": {
      "hex": "#FFFFFF",
      "role": "screen-content",
      "family": "neutral"
    }
  },

  "textTokens": {
    "screen.title": { "hex": "#000000", "role": "text", "against": "screen.content.bg" },
    "screen.artist": { "hex": "#595959", "role": "text", "against": "screen.content.bg" },
    "screen.album": { "hex": "#757575", "role": "text", "against": "screen.content.bg" },
    "screen.trackInfo": {
      "hex": "#868686",
      "role": "text",
      "against": "screen.content.bg"
    },
    "screen.statusbar.text": {
      "hex": "#000000",
      "role": "text",
      "against": "screen.statusbar.bg.from",
      "opacity": 0.85
    }
  },

  "greyFamilies": {
    "neutral": {
      "label": "Neutral",
      "oklchHue": 0,
      "oklchChroma": 0,
      "description": "Pure achromatic"
    },
    "warm": {
      "label": "Warm",
      "oklchHue": 85,
      "oklchChroma": 0.008,
      "description": "Yellow undertone"
    },
    "cool": {
      "label": "Cool",
      "oklchHue": 260,
      "oklchChroma": 0.008,
      "description": "Blue undertone"
    },
    "greige": {
      "label": "Greige",
      "oklchHue": 100,
      "oklchChroma": 0.006,
      "description": "Yellow-green muted"
    },
    "sage": {
      "label": "Sage",
      "oklchHue": 135,
      "oklchChroma": 0.01,
      "description": "Green undertone"
    },
    "lavender": {
      "label": "Lavender",
      "oklchHue": 290,
      "oklchChroma": 0.012,
      "description": "Blue-violet undertone"
    }
  },

  "greyLightnessStops": [
    1.0, 0.975, 0.95, 0.925, 0.9, 0.88, 0.84, 0.8, 0.76, 0.72, 0.68, 0.63, 0.58, 0.53,
    0.48, 0.42, 0.37, 0.32, 0.27, 0.22, 0.15, 0.08, 0.0
  ],

  "oklchPalettes": {
    "case": {
      "lightness": 0.72,
      "chroma": 0.15,
      "steps": 18,
      "hueOffset": 0
    },
    "background": {
      "lightness": 0.88,
      "chroma": 0.07,
      "steps": 14,
      "hueOffset": 30
    }
  },

  "curatedFavorites": {
    "case": [
      { "label": "Bright White", "hex": "#FBFBF8" },
      { "label": "Pearl Gray", "hex": "#E4E4E6" },
      { "label": "Silver", "hex": "#D9DADC" },
      { "label": "Brushed Steel", "hex": "#C7C9CD" },
      { "label": "Gunmetal", "hex": "#535861" },
      { "label": "Black", "hex": "#1B1B1F" }
    ],
    "background": [
      { "label": "Paper White", "hex": "#F3F3EE" },
      { "label": "Studio Warm", "hex": "#E5E5E5" },
      { "label": "Cloud Gray", "hex": "#DBDCDD" },
      { "label": "Slate", "hex": "#A9AFB6" },
      { "label": "Night Graphite", "hex": "#5F6772" }
    ]
  },

  "relationships": {
    "contrastPairs": [
      {
        "description": "Title on screen content",
        "fg": "screen.title",
        "bg": "screen.content.bg",
        "minRatio": 4.5,
        "level": "AA"
      },
      {
        "description": "Artist on screen content",
        "fg": "screen.artist",
        "bg": "screen.content.bg",
        "minRatio": 4.5,
        "level": "AA"
      },
      {
        "description": "Album on screen content",
        "fg": "screen.album",
        "bg": "screen.content.bg",
        "minRatio": 4.5,
        "level": "AA"
      },
      {
        "description": "Track info on screen content",
        "fg": "screen.trackInfo",
        "bg": "screen.content.bg",
        "minRatio": 3.0,
        "level": "AA-large"
      },
      {
        "description": "Wheel label on wheel surface",
        "fg": "wheel.label",
        "bg": "wheel.gradient.via",
        "minRatio": 3.0,
        "level": "AA-large"
      },
      {
        "description": "Status bar text on status bg",
        "fg": "screen.statusbar.text",
        "bg": "screen.statusbar.bg.from",
        "minRatio": 4.5,
        "level": "AA"
      }
    ],
    "perceptualRules": [
      {
        "description": "Backdrop distinct from shell",
        "a": "shell.default",
        "b": "backdrop.default",
        "metric": "deltaE00",
        "minValue": 3.0
      },
      {
        "description": "Shell-to-wheel coherence",
        "a": "shell.default",
        "b": "wheel.gradient.via",
        "metric": "deltaE00",
        "maxValue": 3.0
      },
      {
        "description": "Screen surround contrast to shell",
        "a": "screen.surround.mid",
        "b": "shell.default",
        "metric": "contrastRatio",
        "minValue": 3.0
      }
    ],
    "greyRampRules": {
      "adjacentStopMinDeltaE00": 2.0,
      "undertoneVsNeutralMinDeltaE00": 1.0,
      "undertoneVsNeutralMaxDeltaE00": 4.0,
      "authenticCaseMaxDeltaE00FromReference": 1.0
    }
  }
}
