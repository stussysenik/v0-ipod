{
	"name": "ipod-snapshot",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "node scripts/run-next.mjs dev",
		"dev:raw": "node scripts/run-next.mjs dev",
		"build": "next build",
		"build:analyze": "ANALYZE=true next build",
		"start": "node scripts/run-next.mjs start",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:debug": "playwright test --debug",
		"test:unit": "bun test",
		"test:coverage": "bun test --coverage",
		"lint": "eslint . --ext .ts,.tsx",
		"lint:fix": "eslint . --ext .ts,.tsx --fix",
		"format": "prettier --write \"**/*.{ts,tsx,json,css,mjs,md}\"",
		"format:check": "prettier --check \"**/*.{ts,tsx,json,css,mjs,md}\"",
		"type-check": "tsc --noEmit",
		"validate": "bun run lint && bun run format:check && bun run type-check && bun run storybook:build",
		"prepare": "husky install",
		"ci": "bun run validate && bun run test:unit && bun run build",
		"clean": "rm -rf .next node_modules bun.lock storybook-static && bun install",
		"audit:fix": "bun audit fix",
		"storybook": "storybook dev -p 6006 --no-open",
		"storybook:build": "storybook build -o storybook-static",
		"tokens:extract": "bun run scripts/extract-tokens.ts",
		"tokens:sync": "bun run scripts/sync-tokens.ts",
		"tokens:check": "bun run scripts/check-tokens-fresh.ts",
		"figma:push": "bun run scripts/figma-push.ts",
		"figma:record-frames": "bun run scripts/figma-record-frames.ts",
		"figma:backfill-design-links": "bun run scripts/figma-backfill-design-links.ts",
		"figma:dev": "bun run scripts/figma-dev.ts",
		"figma:check-token": "bun run scripts/figma-check-token.ts",
		"figma:check-parity": "bun run scripts/check-code-connect-parity.ts",
		"figma:check-coverage": "bun run scripts/check-story-coverage.ts",
		"scaffold:component": "bun run scripts/scaffold-component.ts"
	},
