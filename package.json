{
  "name": "ipod-snapshot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "next build",
    "start": "node scripts/run-next.mjs start",
    "pi-research": "python3 plugins/pi-research/scripts/pi_research.py",
    "pi-research:smoke": "python3 plugins/pi-research/scripts/validate_pi_research.py --require-key",
    "test": "playwright test --project=chromium",
    "test:mobile": "playwright test --project=mobile",
    "test:perf": "playwright test --project=perf",
    "test:all": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,mjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css,mjs}\"",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run format:check && npm run type-check",
    "validate:colors": "npx tsx scripts/validate-color-manifest.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "^0.182.0",
    "@vercel/analytics": "1.3.1",
    "autoprefixer": "^10.4.20",
    "gifenc": "^1.0.2",
    "html-to-image": "^1.11.13",
    "html2canvas": "latest",
    "lucide-react": "^0.454.0",
    "next": "15.2.6",
    "postprocessing": "^6.38.2",
    "react": "^19",
    "react-dom": "^19",
    "sonner": "^1.7.4",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.57.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "agentation": "^2.3.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "postcss": "^8.5",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
