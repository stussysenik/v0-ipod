{
	"name": "ipod-snapshot",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.28.0",
	"scripts": {
		"media:sync": "node scripts/sync-portfolio-media.mjs",
		"feed:build": "bun run scripts/build-portfolio-feed.ts",
		"predev": "node scripts/sync-portfolio-media.mjs",
		"dev": "node scripts/run-next.mjs dev",
		"dev:raw": "CLOUDFLARE_TUNNEL=0 node scripts/run-next.mjs dev",
		"prebuild": "node scripts/sync-portfolio-media.mjs",
		"build": "next build --webpack",
		"start": "node scripts/run-next.mjs start",
		"cursor:harness": "node scripts/cursor-harness.mjs",
		"lint": "oxlint . --nextjs-plugin --react-plugin --jsx-a11y-plugin --ignore-pattern '.next/**' --ignore-pattern '.next-dev/**' --ignore-pattern 'node_modules/**' --ignore-pattern 'packages/**/node_modules/**' --ignore-pattern 'public/**' --ignore-pattern 'scripts/**' --ignore-pattern 'ipod-classic.tsx'",
		"lint:fix": "oxlint . --fix --nextjs-plugin --react-plugin --jsx-a11y-plugin --ignore-pattern '.next/**' --ignore-pattern '.next-dev/**' --ignore-pattern 'node_modules/**' --ignore-pattern 'packages/**/node_modules/**' --ignore-pattern 'public/**' --ignore-pattern 'scripts/**' --ignore-pattern 'ipod-classic.tsx'",
		"lint:eslint": "eslint . --ext .ts,.tsx",
		"lint:eslint:fix": "eslint . --ext .ts,.tsx --fix",
		"type-check": "node scripts/type-check.mjs",
		"validate": "bun run lint && bun run type-check",
		"clean:next": "rm -rf .next .next-dev",
		"storybook": "storybook dev -p 6006",
		"test": "pnpm test:unit && pnpm test:e2e",
		"test:e2e": "playwright test",
		"test:exports": "playwright test tests/export-downloads.spec.ts",
		"test:exports:prod": "pnpm build && PLAYWRIGHT_USE_PROD_SERVER=1 playwright test tests/export-downloads.spec.ts",
		"test:unit": "vitest run --project unit",
		"build-storybook": "storybook build",
		"storybook:test": "vitest run --project storybook",
		"storybook:validate": "pnpm build-storybook && pnpm storybook:test",
		"prepare": "husky",
		"og:render": "bun run scripts/render-og.ts"
	},
	"dependencies": {
		"@cloudflare/kumo": "^2.2.1",
		"@cursor/sdk": "^1.0.7",
		"@ducanh2912/next-pwa": "^10.2.9",
		"@hookform/resolvers": "^3.10.0",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.5.0",
		"@react-three/postprocessing": "^3.0.4",
		"@theatre/core": "^0.7.2",
		"@theatre/r3f": "^0.7.2",
		"@theatre/studio": "^0.7.2",
		"@types/three": "^0.182.0",
		"@unocss/postcss": "^66.7.0",
		"@unocss/preset-uno": "^66.7.0",
		"@unocss/webpack": "^66.7.0",
		"@vanilla-extract/css": "^1.20.1",
		"@vanilla-extract/next-plugin": "^2.5.2",
		"@vercel/analytics": "1.3.1",
		"@xstate/react": "^6.1.0",
		"autoprefixer": "^10.4.20",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "1.0.4",
		"date-fns": "4.1.0",
		"effect": "^3.21.2",
		"embla-carousel-react": "8.5.1",
		"gifenc": "^1.0.2",
		"html-to-image": "^1.11.13",
		"html2canvas": "latest",
		"input-otp": "1.4.1",
		"lit": "^3.3.3",
		"lodash": "latest",
		"lucide-react": "^0.454.0",
		"mp4-muxer": "5.2.2",
		"next": "16.2.6",
		"next-themes": "^0.4.6",
		"pocketbase": "^0.27.0",
		"posthog-js": "^1.396.1",
		"postprocessing": "^6.38.2",
		"react": "^19",
		"react-aria-components": "^1.17.0",
		"react-day-picker": "9.8.0",
		"react-dom": "^19",
		"react-hook-form": "^7.60.0",
		"react-resizable-panels": "^2.1.7",
		"recharts": "2.15.4",
		"sonner": "^1.7.4",
		"three": "^0.182.0",
		"unocss": "^66.7.0",
		"vaul": "^1.1.2",
		"xstate": "^5.31.1",
		"zod": "3.25.76"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		]
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.2",
		"@eslint/eslintrc": "^3.3.3",
		"@playwright/test": "^1.59.1",
		"@react-three/eslint-plugin": "^0.1.2",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/addon-vitest": "^10.3.5",
		"@storybook/nextjs-vite": "^10.3.5",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"@unocss/reset": "^66.7.3",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"agentation": "^2.3.2",
		"eslint": "^9.0.0",
		"eslint-config-next": "^16.1.6",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-storybook": "^10.3.5",
		"eslint-plugin-unicorn": "^64.0.0",
		"husky": "^9.1.7",
		"jsdom": "^25.0.1",
		"oxlint": "^1.62.0",
		"playwright": "^1.59.1",
		"postcss": "^8.5",
		"storybook": "^10.3.5",
		"typescript": "^5",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	}
}
