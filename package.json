{
	"name": "ipod-snapshot",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.28.0",
	"scripts": {
		"dev": "turbo run dev",
		"dev:raw": "CLOUDFLARE_TUNNEL=0 turbo run dev",
		"build": "turbo run build",
		"start": "pnpm --filter @ipod/web run start",
		"type-check": "turbo run type-check",
		"cursor:harness": "node tools/scripts/cursor-harness.mjs",
		"lint": "oxlint . --nextjs-plugin --react-plugin --jsx-a11y-plugin --ignore-pattern '**/.next/**' --ignore-pattern '**/.next-dev/**' --ignore-pattern '**/node_modules/**' --ignore-pattern '**/public/**' --ignore-pattern 'tools/scripts/**' --ignore-pattern '**/ipod-classic.tsx'",
		"lint:fix": "oxlint . --fix --nextjs-plugin --react-plugin --jsx-a11y-plugin --ignore-pattern '**/.next/**' --ignore-pattern '**/.next-dev/**' --ignore-pattern '**/node_modules/**' --ignore-pattern '**/public/**' --ignore-pattern 'tools/scripts/**' --ignore-pattern '**/ipod-classic.tsx'",
		"lint:eslint": "eslint . --ext .ts,.tsx",
		"lint:eslint:fix": "eslint . --ext .ts,.tsx --fix",
		"validate": "pnpm lint && pnpm type-check",
		"clean:next": "pnpm --filter @ipod/web run clean:next",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"storybook:test": "vitest run --project storybook",
		"storybook:validate": "pnpm build-storybook && pnpm storybook:test",
		"test": "pnpm test:unit && pnpm test:e2e",
		"test:e2e": "playwright test",
		"test:exports": "playwright test apps/web/tests/export-downloads.spec.ts",
		"test:exports:prod": "pnpm --filter @ipod/web run build && PLAYWRIGHT_USE_PROD_SERVER=1 playwright test apps/web/tests/export-downloads.spec.ts",
		"test:unit": "vitest run --project unit",
		"prepare": "husky"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild", "sharp"],
		"supportedArchitectures": {
			"os": ["current"],
			"cpu": ["current"]
		}
	},
	"devDependencies": {
		"@ipod/config": "workspace:*",
		"@chromatic-com/storybook": "^5.1.2",
		"@eslint/eslintrc": "^3.3.3",
		"@playwright/test": "^1.59.1",
		"@storybook/addon-a11y": "^10.3.5",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/addon-vitest": "^10.3.5",
		"@storybook/nextjs-vite": "^10.3.5",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"agentation": "^2.3.2",
		"eslint": "^9.0.0",
		"eslint-config-next": "^16.1.6",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-storybook": "^10.3.5",
		"eslint-plugin-unicorn": "^64.0.0",
		"husky": "^9.1.7",
		"oxlint": "^1.62.0",
		"playwright": "^1.59.1",
		"storybook": "^10.3.5",
		"tailwindcss": "^3.4.17",
		"turbo": "^2.5.8",
		"typescript": "^5",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	}
}
