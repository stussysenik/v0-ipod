{
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"printWidth": 100,
	"tabWidth": 8,
	"useTabs": true,
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "always",
	"endOfLine": "lf",
	"overrides": [
		{
			"files": "*.md",
			"options": {
				"printWidth": 80,
				"tabWidth": 2,
				"useTabs": false,
				"proseWrap": "always"
			}
		},
		{
			"files": "*.{yml,yaml}",
			"options": {
				"tabWidth": 2,
				"useTabs": false,
				"singleQuote": true
			}
		}
	]
}
