{
	"name": "@ipod/ipod-wc",
	"version": "0.1.0",
	"description": "Framework-native <ipod-classic> custom element — an embeddable, white-label iPod feed browser.",
	"type": "module",
	"private": true,
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./element": "./src/ipod-classic.ts"
	},
	"scripts": {
		"generate-uno": "node scripts/generate-uno.mjs",
		"build": "node scripts/generate-uno.mjs && esbuild src/index.ts --bundle --format=esm --minify --outfile=dist/ipod-classic.js"
	},
	"devDependencies": {
		"esbuild": "^0.27.7",
		"unocss": "^66.7.0"
	},
	"peerDependencies": {
		"lit": "^3"
	}
}
