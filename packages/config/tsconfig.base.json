{
	"//": "Shared TypeScript style preset for the whole workspace. Topology-specific options (baseUrl, path aliases) live in the repo-root tsconfig.base.json, which extends this.",
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"target": "ES2022",
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"forceConsistentCasingInFileNames": true,
		"verbatimModuleSyntax": true
	}
}
