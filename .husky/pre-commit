#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|json|css|md)$' || true)

if [ -z "$STAGED_FILES" ]; then
  echo "✓ No relevant files staged"
  exit 0
fi

echo "Files to check:"
echo "$STAGED_FILES"
echo ""

# Run lint on staged files (only if any JS/TS files are staged — otherwise
# eslint runs against the whole project and trips on unrelated rules).
LINTABLE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx)$' || true)
if [ -n "$LINTABLE_FILES" ]; then
  echo "📝 Running ESLint..."
  bunx eslint --fix $LINTABLE_FILES
  if [ $? -ne 0 ]; then
    echo "❌ ESLint failed"
    exit 1
  fi
else
  echo "📝 Skipping ESLint (no JS/TS files staged)"
fi

# Run Prettier on staged files
echo "💅 Running Prettier..."
bunx prettier --write $(echo "$STAGED_FILES" | xargs)
if [ $? -ne 0 ]; then
  echo "❌ Prettier failed"
  exit 1
fi

# Re-stage formatted files
echo "$STAGED_FILES" | xargs git add

# Type check (only if TS/JS files are staged — a project-wide check on a
# markdown-only commit is meaningless and flags unrelated in-tree work).
if [ -n "$LINTABLE_FILES" ]; then
  echo "🔷 Running TypeScript check..."
  bun run type-check
  if [ $? -ne 0 ]; then
    echo "❌ TypeScript check failed"
    exit 1
  fi
else
  echo "🔷 Skipping TypeScript check (no JS/TS files staged)"
fi

echo "✅ All checks passed!"
