{
  "name": "ipod-moonbit-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run res:build && npm run moon:build && vite build",
    "moon:build": "cd .. && moon build --target js --release && cp _build/js/release/build/cmd/main/main.js web/js/ipod_moonbit.js",
    "moon:watch": "cd .. && moon build --target js --watch",
    "res:build": "rescript build",
    "res:watch": "rescript watch",
    "preview": "vite preview"
  },
  "dependencies": {
    "@rescript/core": "^1.6.0",
    "@rescript/react": "^0.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "rescript": "^12.0.0",
    "vite": "^5.4.0"
  }
}
