root = true

# Code: TABS at 8 (Linux kernel style)
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 8
tab_width = 8
max_line_length = 100

# TypeScript/JavaScript
[*.{ts,tsx,js,jsx}]
indent_style = tab
indent_size = 8
tab_width = 8

# CSS/SCSS
[*.{css,scss}]
indent_style = tab
indent_size = 8

# Markdown: spaces at 2 (readability)
[*.md]
indent_style = space
indent_size = 2
tab_width = 2
max_line_length = 80
trim_trailing_whitespace = false

# YAML/JSON: spaces at 2 (format requirement)
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2
tab_width = 2

# Makefile: tabs (required)
[Makefile]
indent_style = tab
