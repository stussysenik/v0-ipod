{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "description": "Shared design-token seed for reusable UI primitives outside the iPod product assembly.",
  "iconButton": {
    "size": 44,
    "radius": 9999,
    "motion": {
      "durationMs": 200,
      "hoverScale": 1.03,
      "activeScale": 1.04,
      "pressScale": 0.98
    },
    "badge": {
      "border": "#E8B65A",
      "background": "#FFF4CC",
      "foreground": "#7A5612",
      "shadow": "0 4px 10px rgba(0,0,0,0.12)"
    },
    "tooltip": {
      "border": "rgba(0,0,0,0.1)",
      "background": "rgba(255,255,255,0.92)",
      "foreground": "rgba(0,0,0,0.72)",
      "shadow": "0 8px 16px rgba(0,0,0,0.08)"
    },
    "variants": {
      "default": {
        "border": "#CDD2D8",
        "background": "linear-gradient(180deg,rgba(255,255,255,0.98),rgba(237,239,242,0.96))",
        "foreground": "#111315",
        "shadow": "none",
        "hover": {
          "border": "#BFC5CC",
          "background": "linear-gradient(180deg,rgba(255,255,255,1),rgba(240,242,245,0.98))",
          "foreground": "#111315",
          "shadow": "0 12px 20px rgba(0,0,0,0.14), inset 0 1px 0 rgba(255,255,255,1), inset 0 -1px 0 rgba(0,0,0,0.07)"
        }
      },
      "contrast": {
        "border": "#0F1114",
        "background": "#111315",
        "foreground": "#FFFFFF",
        "shadow": "0 12px 20px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.12)",
        "hover": {
          "border": "#0F1114",
          "background": "#191C20",
          "foreground": "#FFFFFF",
          "shadow": "0 14px 24px rgba(0,0,0,0.24), inset 0 1px 0 rgba(255,255,255,0.12)"
        }
      },
      "active": {
        "border": "#0F1114",
        "background": "#111315",
        "foreground": "#FFFFFF",
        "shadow": "0 12px 20px rgba(0,0,0,0.22), inset 0 1px 0 rgba(255,255,255,0.14)"
      }
    }
  }
}
